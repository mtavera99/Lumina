# Identificador publico del cliente OAuth web de Google.
VITE_GOOGLE_CLIENT_ID=

# URL completa de la funcion Netlify intelligence.mjs cuando el frontend se publica en GitHub Pages.
VITE_INTELLIGENCE_API_URL=

# Variables privadas: configurar solo en Netlify, nunca con prefijo VITE_ ni en el repositorio.
# GOOGLE_OAUTH_CLIENT_ID=el mismo ID publico usado en VITE_GOOGLE_CLIENT_ID
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.6-flash
# HUBSPOT_PRIVATE_APP_TOKEN=
# INTELLIGENCE_ALLOWED_ORIGINS=https://mtavera99.github.io

# --- Meta Conversions API (evento Lead server-side, con deduplicacion) ---
# Token de acceso de la Conversions API (Administrador de eventos > Configuracion > Conversions API > Generar token de acceso).
# META_CAPI_TOKEN=
# (Opcional) Sobreescribe el ID del pixel si difiere del de la landing.
# META_PIXEL_ID=2484699815368533
# (Opcional) Codigo para "Probar eventos" mientras verificas la integracion. Quitar en produccion.
# META_TEST_EVENT_CODE=

# --- Meta Marketing API: proxy de metricas en tiempo real (meta-insights.mjs) ---
# Token de acceso con permiso ads_read (recomendado: token de Usuario del Sistema, larga duracion).
# META_ACCESS_TOKEN=
# ID de la cuenta publicitaria (con o sin el prefijo act_). Ej: act_1234567890
# META_AD_ACCOUNT_ID=
# (Opcional) Version de la Graph API; por defecto v21.0.
# META_API_VERSION=v21.0
# (Opcional) Origenes permitidos para CORS del proxy de metricas, separados por coma.
# METRICS_ALLOWED_ORIGINS=https://mtavera99.github.io
