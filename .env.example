# Identificador publico del cliente OAuth web de Google.
VITE_GOOGLE_CLIENT_ID=

# URL completa de la funcion Netlify intelligence.mjs cuando el frontend se publica en GitHub Pages.
VITE_INTELLIGENCE_API_URL=

# Variables privadas: configurar solo en Netlify, nunca con prefijo VITE_ ni en el repositorio.
# GOOGLE_OAUTH_CLIENT_ID=el mismo ID publico usado en VITE_GOOGLE_CLIENT_ID
# HUBSPOT_PRIVATE_APP_TOKEN=
